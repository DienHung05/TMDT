/* Layout */
.pvcb-layout {
    display: grid; grid-template-columns: 1fr 280px; gap: 20px;
    padding-top: 28px; align-items: start;
}
@media (max-width: 960px) { .pvcb-layout { grid-template-columns: 1fr; } }

/* Steps/Slots */
.pvcb-steps { display:flex; flex-direction:column; gap:10px; }
.pvcb-slot {
    background: linear-gradient(145deg,rgba(255,255,255,.04),rgba(255,255,255,.01));
    border: 1px solid rgba(255,255,255,.07); border-radius: 12px; overflow:hidden;
    transition: border-color .2s;
}
.pvcb-slot.is-filled { border-color: rgba(99,102,241,.5); background: linear-gradient(145deg,rgba(99,102,241,.09),rgba(139,92,246,.04)); }
.pvcb-slot.is-open-picker { border-color: rgba(99,102,241,.8); }
.pvcb-slot__header {
    display:flex; align-items:center; gap:12px; padding:13px 16px; cursor:default;
}
.pvcb-slot__step {
    min-width:24px; height:24px; border-radius:7px;
    background:rgba(99,102,241,.15); border:1px solid rgba(99,102,241,.25);
    color:#818cf8; font-size:11px; font-weight:800;
    display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.pvcb-slot__icon {
    width:34px; height:34px; display:flex; align-items:center; justify-content:center;
    border-radius:9px; flex-shrink:0; color:#818cf8;
    background:rgba(99,102,241,.1); border:1px solid rgba(99,102,241,.18);
}
.pvcb-slot__icon svg { width:18px; height:18px; }
.pvcb-slot__title-wrap { flex:1; }
.pvcb-slot__label { display:block; font-size:14px; font-weight:700; color:#e2e8f0; }
.pvcb-slot__sub   { display:block; font-size:11px; color:#475569; }
.pvcb-slot__status {
    width:20px; height:20px; border-radius:50%; border:2px solid #1e293b;
    display:flex; align-items:center; justify-content:center; flex-shrink:0;
    transition: background .25s, border-color .25s, box-shadow .25s;
}
.pvcb-check { width:10px; height:10px; opacity:0; transition:opacity .2s; stroke:#fff; }
.pvcb-slot.is-filled .pvcb-slot__status {
    background:#22c55e; border-color:#22c55e; box-shadow:0 0 10px rgba(34,197,94,.4);
}
.pvcb-slot.is-filled .pvcb-check { opacity:1; }
/* Slot body */
.pvcb-slot__body { padding:0 16px 14px; }
.pvcb-avail { font-size:11px; color:#6366f1; display:block; margin-bottom:8px; }
.pvcb-choose-btn {
    display:flex; align-items:center; justify-content:center; gap:7px;
    width:100%; padding:10px;
    border: 2px dashed rgba(99,102,241,.35); border-radius:9px;
    color:#818cf8; font-size:12px; font-weight:700;
    background:rgba(99,102,241,.04); cursor:pointer; transition:all .2s;
}
.pvcb-choose-btn svg { width:13px; height:13px; }
.pvcb-choose-btn:hover { border-color:rgba(99,102,241,.7); background:rgba(99,102,241,.1); color:#a5b4fc; }
.pvcb-fallback-link { color:#6366f1; text-decoration:underline; }
/* Selected */
.pvcb-sel {
    display:flex; align-items:center; gap:10px; padding:10px;
    background:rgba(99,102,241,.07); border:1px solid rgba(99,102,241,.22); border-radius:9px;
}
.pvcb-sel-img { width:48px; height:48px; object-fit:contain; border-radius:6px; background:rgba(255,255,255,.06); flex-shrink:0; }
.pvcb-sel-info { flex:1; min-width:0; }
.pvcb-sel-name  { font-size:12px; font-weight:600; color:#e2e8f0; margin:0 0 3px;
    display:-webkit-box; -webkit-line-clamp:2; line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
.pvcb-sel-price { font-size:13px; font-weight:800; color:#818cf8; margin:0; }
.pvcb-sel-btns { display:flex; flex-direction:column; gap:4px; flex-shrink:0; }
.pvcb-change-btn {
    padding:5px 9px; border-radius:5px; font-size:11px; font-weight:700;
    background:rgba(99,102,241,.15); border:1px solid rgba(99,102,241,.3); color:#818cf8;
    cursor:pointer; transition:background .2s;
}
.pvcb-change-btn:hover { background:rgba(99,102,241,.28); }
.pvcb-remove-btn {
    padding:5px 7px; border-radius:5px;
    background:rgba(239,68,68,.1); border:1px solid rgba(239,68,68,.25); color:#f87171;
    cursor:pointer; display:flex; align-items:center; justify-content:center; transition:background .2s;
}
.pvcb-remove-btn svg { width:11px; height:11px; }
.pvcb-remove-btn:hover { background:rgba(239,68,68,.25); }
/* Picker */
.pvcb-picker { border-top:1px solid rgba(99,102,241,.18); background:rgba(0,0,0,.28); }
.pvcb-picker__head {
    display:flex; align-items:center; justify-content:space-between;
    padding:11px 16px; font-size:12px; font-weight:600; color:#a5b4fc;
    border-bottom:1px solid rgba(99,102,241,.1);
}
.pvcb-picker__close {
    width:26px; height:26px; border-radius:7px;
    background:rgba(239,68,68,.1); border:1px solid rgba(239,68,68,.2);
    color:#f87171; cursor:pointer; display:flex; align-items:center; justify-content:center;
}
.pvcb-picker__close svg { width:12px; height:12px; }
.pvcb-picker__close:hover { background:rgba(239,68,68,.25); }
.pvcb-picker__grid {
    display:grid; grid-template-columns:repeat(auto-fill,minmax(130px,1fr));
    gap:9px; padding:12px 14px; max-height:320px; overflow-y:auto;
    scrollbar-width:thin; scrollbar-color:rgba(99,102,241,.4) transparent;
}
/* Product card (inside picker) */
.pvcb-prod {
    background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.07);
    border-radius:10px; padding:10px; cursor:pointer; position:relative;
    display:flex; flex-direction:column; gap:6px;
    transition: border-color .2s, transform .2s, background .2s;
}
.pvcb-prod:hover { border-color:rgba(99,102,241,.5); background:rgba(99,102,241,.08); transform:translateY(-2px); }
.pvcb-prod__disc {
    position:absolute; top:5px; right:5px; padding:2px 6px; border-radius:4px;
    background:linear-gradient(135deg,#ef4444,#f97316); color:#fff; font-size:9px; font-weight:800;
}
.pvcb-prod__img { height:68px; display:flex; align-items:center; justify-content:center; }
.pvcb-prod__img img { max-width:100%; max-height:64px; object-fit:contain; }
.pvcb-prod__name {
    font-size:11px; font-weight:600; color:#cbd5e1; margin:0;
    display:-webkit-box; -webkit-line-clamp:2; line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;
}
.pvcb-prod__price {
    font-size:12px; font-weight:800; margin:0;
    background:linear-gradient(135deg,#6366f1,#a855f7);
    -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent;
}
.pvcb-prod__btn {
    width:100%; padding:6px; border-radius:6px; font-size:11px; font-weight:700;
    background:linear-gradient(135deg,#6366f1,#8b5cf6); color:#fff;
    border:none; cursor:pointer; transition:opacity .2s; margin-top:auto;
}
.pvcb-prod__btn:hover { opacity:.85; }
/* Sidebar */
.pvcb-sidebar { position:sticky; top:74px; }
.pvcb-sum-card {
    background:linear-gradient(145deg,rgba(99,102,241,.10),rgba(139,92,246,.06));
    border:1px solid rgba(99,102,241,.25); border-radius:16px; padding:22px;
}
.pvcb-sum-title { font-size:15px; font-weight:800; color:#e2e8f0; margin:0 0 14px; }
.pvcb-sum-list { list-style:none; padding:0; margin:0 0 16px; min-height:40px; }
.pvcb-sum-list li {
    display:flex; justify-content:space-between; padding:7px 0;
    border-bottom:1px solid rgba(255,255,255,.05); font-size:11px; color:#94a3b8;
}
.pvcb-sum-list li:last-child { border-bottom:none; }
.pvcb-sum-list li span:last-child { color:#818cf8; font-weight:700; white-space:nowrap; margin-left:8px; }
.pvcb-sum-empty { font-size:11px; color:#334155; font-style:italic; justify-content:center !important; }
.pvcb-sum-divider { border:0; border-top:1px solid rgba(255,255,255,.07); margin:0 0 14px; }
.pvcb-sum-row {
    display:flex; justify-content:space-between; align-items:baseline; margin-bottom:14px;
    font-size:12px; color:#64748b;
}
.pvcb-sum-row strong {
    font-size:20px; font-weight:900;
    background:linear-gradient(135deg,#6366f1,#a855f7);
    -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent;
}
.pvcb-sum-reset {
    display:flex; align-items:center; gap:6px; justify-content:center; width:100%;
    padding:8px; border-radius:8px; border:1px solid rgba(239,68,68,.25);
    color:#f87171; background:rgba(239,68,68,.06); font-size:11px; font-weight:700; cursor:pointer;
    transition:background .2s;
}
.pvcb-sum-reset svg { width:13px; height:13px; }
.pvcb-sum-reset:hover { background:rgba(239,68,68,.18); }
/* Info box */
.pvcb-info-box {
    display:flex; gap:10px; align-items:flex-start; margin-top:12px;
    padding:14px; background:rgba(255,255,255,.03); border:1px solid rgba(255,255,255,.07);
    border-radius:12px;
}
.pvcb-info-box svg { width:18px; height:18px; flex-shrink:0; color:#6366f1; margin-top:1px; }
.pvcb-info-box p { font-size:11px; color:#475569; margin:0; line-height:1.6; }
/* Sticky mobile bar */
.pvcb-sticky {
    position:fixed; bottom:0; left:0; right:0;
    background:rgba(8,8,16,.94); border-top:1px solid rgba(99,102,241,.2);
    backdrop-filter:blur(16px); display:flex; align-items:center; gap:10px;
    padding:11px 18px; z-index:100;
}
@media (min-width: 960px) { .pvcb-sticky { display:none; } }
.pvcb-sticky span { color:#64748b; font-size:12px; }
.pvcb-sticky strong {
    flex:1; font-size:18px; font-weight:900;
    background:linear-gradient(135deg,#6366f1,#a855f7);
    -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent;
}
.pvcb-sticky-btn {
    padding:9px 18px; border-radius:9px;
    background:linear-gradient(135deg,#6366f1,#8b5cf6);
    color:#fff; font-size:12px; font-weight:700; text-decoration:none;
}
.pvcb-sticky-btn:hover { opacity:.9; color:#fff; }
</style>

<script>
/* ─── PC Builder State Machine ──────────────────────────────────────────── */
var pvBuild = {};

function pvFmt(n) {
    if (!n) return '0₫';
    return new Intl.NumberFormat('vi-VN', {style:'currency',currency:'VND'}).format(n * 25000)
        .replace('₫','').trim() + '₫';
}

function pvOpen(slot) {
    document.querySelectorAll('.pvcb-picker').forEach(function(e){ e.style.display='none'; });
    document.querySelectorAll('.pvcb-slot').forEach(function(e){ e.classList.remove('is-open-picker'); });
    var picker = document.getElementById('pvPicker-' + slot);
    var slotEl = document.getElementById('pvSlot-' + slot);
    if (picker) picker.style.display = 'block';
    if (slotEl) { slotEl.classList.add('is-open-picker'); slotEl.scrollIntoView({behavior:'smooth',block:'nearest'}); }
}
function pvClose(slot) {
    var p = document.getElementById('pvPicker-' + slot);
    var s = document.getElementById('pvSlot-' + slot);
    if (p) p.style.display = 'none';
    if (s) s.classList.remove('is-open-picker');
}
function pvSelect(slot, id, price, name, image, priceFmt) {
    pvBuild[slot] = {id:id, price:price, name:name, image:image, priceFmt:priceFmt};
    var emptyEl = document.getElementById('pvEmpty-' + slot);
    var selEl   = document.getElementById('pvSel-' + slot);
    var slotEl  = document.getElementById('pvSlot-' + slot);
    if (emptyEl) emptyEl.style.display = 'none';
    if (selEl)   selEl.style.display = 'flex';
    var imgEl   = document.getElementById('pvSelImg-' + slot);
    var nameEl  = document.getElementById('pvSelName-' + slot);
    var priceEl = document.getElementById('pvSelPrice-' + slot);
    if (imgEl)   imgEl.src = image;
    if (nameEl)  nameEl.textContent = name;
    if (priceEl) priceEl.textContent = priceFmt;
    if (slotEl)  slotEl.classList.add('is-filled');
    pvClose(slot);
    pvUpdateSummary();
}
function pvRemove(slot) {
    delete pvBuild[slot];
    var emptyEl = document.getElementById('pvEmpty-' + slot);
    var selEl   = document.getElementById('pvSel-' + slot);
    var slotEl  = document.getElementById('pvSlot-' + slot);
    if (emptyEl) emptyEl.style.display = 'block';
    if (selEl)   selEl.style.display = 'none';
    if (slotEl)  slotEl.classList.remove('is-filled');
    pvUpdateSummary();
}
function pvReset() { Object.keys(pvBuild).forEach(pvRemove); }
function pvUpdateSummary() {
    var keys   = Object.keys(pvBuild);
    var sum    = keys.reduce(function(a,k){ return a + pvBuild[k].price; }, 0);
    var fmt    = sum > 0 ? new Intl.NumberFormat('vi-VN',{style:'currency',currency:'USD'}).format(sum) : '0₫';
    ['pvTotal','pvSideTotal','pvStickyTotal'].forEach(function(id){
        var el = document.getElementById(id); if (el) el.textContent = fmt;
    });
    var list = document.getElementById('pvSumList');
    if (!list) return;
    var empty = document.getElementById('pvSumEmpty');
    if (empty) empty.style.display = keys.length ? 'none' : 'list-item';
    /* Remove previous dynamic items */
    list.querySelectorAll('.pvcb-sum-item').forEach(function(e){ e.remove(); });
    keys.forEach(function(k){
        var li = document.createElement('li'); li.className = 'pvcb-sum-item';
        var left  = document.createElement('span');
        var right = document.createElement('span');
        var n = pvBuild[k].name;
        left.textContent  = n.length > 22 ? n.slice(0,22)+'…' : n;
        right.textContent = pvBuild[k].priceFmt;
        li.appendChild(left); li.appendChild(right);
        list.appendChild(li);
    });
}
document.addEventListener('DOMContentLoaded', pvUpdateSummary);
</script>
