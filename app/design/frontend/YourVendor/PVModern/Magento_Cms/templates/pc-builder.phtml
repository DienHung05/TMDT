$visibility                 = $om->get(\Magento\Catalog\Model\Product\Visibility::class);
$priceCurrency              = $om->get(\Magento\Framework\Pricing\PriceCurrencyInterface::class);
$productVisualResolver      = $om->get(\YourVendor\PVModern\Model\ProductVisualResolver::class);
$store                      = $storeManager->getStore();

function pvPcFindCategoryIds($categoryCollectionFactory, array $names) {
    $wanted = [];
    foreach ($names as $name) {
        $wanted[mb_strtolower(trim((string) $name))] = true;
    }

    $found = [];

    try {
        $collection = $categoryCollectionFactory->create();
        $collection->addAttributeToSelect(['name', 'entity_id'])
            ->addAttributeToFilter('is_active', 1);

        foreach ($collection as $category) {
            $key = mb_strtolower(trim((string) $category->getName()));
            if (isset($wanted[$key])) {
                $found[] = (int) $category->getId();
            }
        }
    } catch (\Throwable $e) {
    }

    return array_values(array_unique(array_filter($found)));
}

function pvPcLoadProducts($productCollectionFactory, $visibility, $priceCurrency, $productVisualResolver, $store, array $categoryIds, $limit = 16) {
    if (empty($categoryIds)) {
        return [];
    }

    $collection = $productCollectionFactory->create();
    $collection->setStoreId((int) $store->getId())
        ->addStoreFilter($store)
        ->addAttributeToSelect(['name', 'sku', 'small_image', 'image', 'thumbnail', 'price', 'special_price'])
        ->addFinalPrice()
        ->addUrlRewrite()
        ->addAttributeToFilter('status', 1)
        ->setVisibility($visibility->getVisibleInCatalogIds())
        ->addCategoriesFilter(['in' => $categoryIds])
        ->setPageSize($limit)
        ->setCurPage(1);
    $collection->getSelect()->order('e.entity_id DESC');

    return pvPcMapItems($collection, $productVisualResolver, $priceCurrency);
}

function pvPcMapItems($collection, $productVisualResolver, $priceCurrency) {
    $items = [];

    foreach ($collection as $product) {
        $regular = (float) $product->getData('price');
        $special = (float) $product->getFinalPrice();
        if ($special <= 0) {
            $special = $regular;
        }

        $disc = ($regular > $special && $regular > 0)
            ? (int) round(100 * (1 - $special / $regular))
            : 0;

        $items[] = [
            'id'        => (int) $product->getId(),
            'name'      => (string) $product->getName(),
            'sku'       => (string) $product->getSku(),
            'url'       => (string) $product->getProductUrl(),
            'image'     => $productVisualResolver->resolveProductImage($product, 'category_page_grid'),
            'price'     => $special ?: $regular,
            'price_fmt' => $priceCurrency->format($special ?: $regular, false),
            'disc'      => $disc,
        ];
    }

    return $items;
}

