/* ── Step 1: Auto-discover category IDs by keyword-matching category names ── */
function pvPcDiscoverCats($categoryCollectionFactory) {
    /* Keywords per slot. More broad = higher chance of matching real categories */
    $slots = [
        'cpu'         => ['cpu', 'processor', 'vi xu ly', 'vi xử lý'],
        'motherboard' => ['motherboard', 'mainboard', 'bo mach', 'bo mạch'],
        'gpu'         => ['gpu', 'vga', 'graphics', 'video', 'card man hinh', 'card màn'],
        'ram'         => ['ram', 'memory', 'ddr'],
        'storage'     => ['ssd', 'nvme', 'o cung', 'ổ cứng', 'hdd', 'storage'],
        'case'        => ['case', 'vo may', 'vỏ máy', 'chassis'],
        'psu'         => ['psu', 'power', 'nguon', 'nguồn'],
        'cooler'      => ['cooler', 'cooling', 'tan nhiet', 'tản nhiệt', 'aio'],
    ];
    $found = [];
    try {
        $col = $categoryCollectionFactory->create();
        $col->addAttributeToSelect(['name', 'entity_id'])
            ->addAttributeToFilter('is_active', 1)
            ->addAttributeToFilter('level', ['gt' => 1]);
        foreach ($col as $cat) {
            $name = strtolower((string)$cat->getName());
            foreach ($slots as $slot => $keywords) {
                if (isset($found[$slot])) continue;
                foreach ($keywords as $kw) {
                    if (str_contains($name, $kw) || strpos($name, $kw) !== false) {
                        $found[$slot] = (int)$cat->getId();
                        break;
                    }
                }
            }
        }
    } catch (\Throwable $e) {}
    return $found;
}

/* ── Step 2: Load products for a slot ───────────────────────────────────── */
function pvPcLoadProducts($productCollectionFactory, $categoryFactory, $visibility, $imageHelper, $priceCurrency, $store, $catId, $keywords, $limit = 12) {
    $om = \Magento\Framework\App\ObjectManager::getInstance();

    $makeCollection = function() use ($productCollectionFactory, $store, $visibility, $limit) {
        $c = $productCollectionFactory->create();
        $c->setStoreId((int)$store->getId())
          ->addStoreFilter($store)
          ->addAttributeToSelect(['name','small_image','price','special_price'])
          ->addFinalPrice()
          ->addUrlRewrite()
          ->addAttributeToFilter('status', 1)
          ->setVisibility($visibility->getVisibleInCatalogIds())
          ->setPageSize($limit)
          ->setCurPage(1);
        return $c;
    };

    $items = [];

    /* ── Try 1: category filter if we found a matching category ── */
    if ($catId) {
        try {
            $cat = $categoryFactory->create()->load($catId);
            if ($cat->getId()) {
                $col = $makeCollection();
                $col->addCategoryFilter($cat);
                $col->getSelect()->order('e.entity_id DESC');
                $col->load();
                if ($col->count() > 0) {
                    return pvPcMapItems($col, $imageHelper, $priceCurrency);
                }
            }
        } catch (\Throwable $e) {}
    }

    /* ── Try 2: OR keyword search across product names ── */
    if ($keywords) {
        try {
            $kwArr = array_filter(
                array_map('trim', preg_split('/[\s|]+/', $keywords)),
                function ($k) { return strlen($k) >= 3; }
            );
            if (!empty($kwArr)) {
                $conditions = array_map(function($kw) {
                    return ['like' => '%' . $kw . '%'];
                }, array_values($kwArr));
                /* Magento 2: array of conditions on same attribute = OR */
                $col = $makeCollection();
                $col->addAttributeToFilter('name', $conditions);
                $col->getSelect()->order('e.entity_id DESC');
                $col->load();
                if ($col->count() > 0) {
                    return pvPcMapItems($col, $imageHelper, $priceCurrency);
                }
            }
        } catch (\Throwable $e) {}
    }

    /* ── Try 3: broad SKU / search (last resort) ── */
    /* Return empty — we'll show the "no products" UI without a fallback dump */
    return [];
}

function pvPcMapItems($collection, $imageHelper, $priceCurrency) {
    $items = [];
    foreach ($collection as $product) {
        $regular = (float)$product->getData('price');
        $special = (float)$product->getFinalPrice();
        if ($special <= 0) $special = $regular;
        $disc = ($regular > $special && $regular > 0)
            ? (int)round(100 * (1 - $special / $regular)) : 0;
        $items[] = [
            'id'        => (int)$product->getId(),
            'name'      => (string)$product->getName(),
            'sku'       => (string)$product->getSku(),
            'url'       => (string)$product->getProductUrl(),
            'image'     => (string)$imageHelper->init($product, 'category_page_grid')->getUrl(),
            'price'     => $special ?: $regular,
            'price_fmt' => $priceCurrency->format($special ?: $regular, false),
            'disc'      => $disc,
        ];
    }
    return $items;
}

