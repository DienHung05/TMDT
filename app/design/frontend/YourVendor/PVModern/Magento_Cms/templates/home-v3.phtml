$store = $storeManager->getStore();
$rootCategoryId = (int)$store->getRootCategoryId();
$categoryCollection = $categoryCollectionFactory->create();
$categoryCollection->addAttributeToSelect(['name','url_key'])->addAttributeToFilter('is_active',1)->addFieldToFilter('parent_id',$rootCategoryId)->setOrder('position','ASC');
$categories=[]; foreach($categoryCollection as $category){ $categories[]=['id'=>(int)$category->getId(),'name'=>(string)$category->getName(),'slug'=>strtolower((string)$category->getUrlKey() ?: preg_replace('/[^a-z0-9]+/i','-',(string)$category->getName()))]; }
$productCollection=$productCollectionFactory->create();
$productCollection->addStoreFilter($store)->addAttributeToSelect(['name','small_image','price','special_price','short_description','description','sku','created_at'])->addMinimalPrice()->addFinalPrice()->addTaxPercents()->addUrlRewrite()->addAttributeToFilter('status',1)->addAttributeToFilter('visibility',['in'=>[2,3,4]])->setPageSize(12)->setOrder('created_at','DESC');
$fallbackImages=[
'https://images.unsplash.com/photo-1591488320449-011701bb6704?auto=format&fit=crop&w=900&q=80',
'https://images.unsplash.com/photo-1517336714739-489689fd1ca8?auto=format&fit=crop&w=900&q=80',
'https://images.unsplash.com/photo-1587202372775-e229f172b9d7?auto=format&fit=crop&w=900&q=80',
'https://images.unsplash.com/photo-1527443224154-c4a3942d3acf?auto=format&fit=crop&w=900&q=80'];
$products=[]; $fallbackIndex=0;
foreach($productCollection as $product){
  try{$stockItem=$stockRegistry->getStockItem((int)$product->getId()); $qty=$stockItem?(int)max(0,floor((float)$stockItem->getQty())):0; $isInStock=$stockItem?(bool)$stockItem->getIsInStock():false;}catch(\Throwable $e){$qty=0;$isInStock=false;}
  try{$imageUrl=$imageHelper->init($product,'product_page_image_medium')->getUrl();}catch(\Throwable $e){$imageUrl=$fallbackImages[$fallbackIndex%count($fallbackImages)];}
  if(!$imageUrl || strpos($imageUrl,'placeholder')!==false){$imageUrl=$fallbackImages[$fallbackIndex%count($fallbackImages)];}
  $fallbackIndex++;
  $categoryNames=[]; foreach((array)$product->getCategoryIds() as $cid){ foreach($categories as $catItem){ if((int)$catItem['id']===(int)$cid){$categoryNames[]=$catItem['name'];}}}
  $finalPrice=(float)$product->getFinalPrice();
  $desc=trim(strip_tags((string)$product->getShortDescription())); if($desc===''){$desc=trim(strip_tags((string)$product->getDescription()));} $desc=mb_substr($desc,0,220);
  $productType=(string)$product->getTypeId(); $canAddDirectly=$product->isSaleable() && $productType==='simple';
  preg_match('/^([A-Za-z0-9]+)/',(string)$product->getName(),$m);
  $products[]=['id'=>(int)$product->getId(),'name'=>(string)$product->getName(),'sku'=>(string)$product->getSku(),'url'=>(string)$product->getProductUrl(),'image'=>(string)$imageUrl,'price'=>round($finalPrice,2),'price_formatted'=>$priceHelper->currency($finalPrice,true,false),'description'=>$desc,'categories'=>$categoryNames,'category_label'=>count($categoryNames)?$categoryNames[0]:'General','brand'=>$m?strtoupper($m[1]):'MIXIII','qty'=>$qty,'availability'=>!$isInStock?'Out of stock':($qty<=5?'Low stock':'In stock'),'is_new'=>true,'is_featured'=>true,'add_url'=>$canAddDirectly?$cartHelper->getAddUrl($product):'','can_add'=>$canAddDirectly];
}
if(!count($products)){
 $products=[['id'=>0,'name'=>'RTX 5090 Founders Edition','sku'=>'RTX-5090-FE','url'=>'#','image'=>$fallbackImages[0],'price'=>1999.00,'price_formatted'=>'$1,999.00','description'=>'Top-tier GPU placeholder product shown because your catalog is currently empty.','categories'=>['GPU'],'category_label'=>'GPU','brand'=>'NVIDIA','qty'=>199,'availability'=>'In stock','is_new'=>true,'is_featured'=>true,'add_url'=>'#','can_add'=>false],
 ['id'=>0,'name'=>'MacBook Pro M5 Max','sku'=>'MBP-M5-MAX','url'=>'#','image'=>$fallbackImages[1],'price'=>3499.00,'price_formatted'=>'$3,499.00','description'=>'Premium laptop placeholder while waiting for real admin products.','categories'=>['Laptop'],'category_label'=>'Laptop','brand'=>'APPLE','qty'=>19,'availability'=>'In stock','is_new'=>true,'is_featured'=>true,'add_url'=>'#','can_add'=>false],
 ['id'=>0,'name'=>'Ryzen 9 9950X3D','sku'=>'RYZEN-9950X3D','url'=>'#','image'=>$fallbackImages[2],'price'=>749.00,'price_formatted'=>'$749.00','description'=>'High-end CPU placeholder for the premium showcase.','categories'=>['CPU'],'category_label'=>'CPU','brand'=>'AMD','qty'=>8,'availability'=>'Low stock','is_new'=>true,'is_featured'=>true,'add_url'=>'#','can_add'=>false]];
}
$heroProducts=array_slice($products,0,min(3,count($products))); $recentProducts=array_slice($products,0,min(8,count($products))); $selected=$products[0];
$initialInStock=0; $initialLowStock=0; $maxPrice=0;
foreach($products as $prod){ if($prod['availability']==='In stock'){$initialInStock++;} elseif($prod['availability']==='Low stock'){$initialLowStock++;} if((float)$prod['price']>$maxPrice){$maxPrice=(float)$prod['price'];}}
?>
