$normalize = static function ($value) {
    $value = strtolower(trim((string) $value));
    $value = preg_replace('/[^a-z0-9]+/', '-', $value);
    return trim((string) $value, '-');
};

$getAttrText = static function ($product, $code) {
    try {
        $value = $product->getAttributeText($code);
        if (is_array($value)) {
            $value = implode(', ', array_filter($value));
        }
        if ($value !== null && $value !== false && $value !== '') {
            return trim((string) $value);
        }
    } catch (\Throwable $e) {
    }

    $value = $product->getData($code);
    if (is_array($value)) {
        $value = implode(', ', array_filter($value));
    }

    return ($value !== null && $value !== false && $value !== '') ? trim((string) $value) : '';
};

$inferCategory = static function ($name, array $categoryNames, $typeId) {
    $haystack = strtolower($name . ' ' . implode(' ', $categoryNames) . ' ' . $typeId);

    $map = [
        'gpu' => ['gpu', 'graphics', 'graphics-card', 'geforce', 'rtx', 'radeon', 'vga'],
        'cpu' => ['cpu', 'processor', 'ryzen', 'threadripper', 'intel core', 'core i', 'xeon'],
        'laptop' => ['laptop', 'notebook', 'macbook', 'ultrabook'],
        'desktop' => ['desktop', 'pc', 'workstation', 'mac studio', 'mac mini', 'tower'],
    ];

    foreach ($map as $label => $keywords) {
        foreach ($keywords as $keyword) {
            if (strpos($haystack, $keyword) !== false) {
                return strtoupper($label);
            }
        }
    }

    if (!empty($categoryNames)) {
        return $categoryNames[0];
    }

    return ucfirst((string) $typeId);
};

$getFilterSlugs = static function ($name, array $categoryNames, $displayCategory, $typeId) use ($normalize) {
    $slugs = ['all'];
    $haystack = strtolower($name . ' ' . implode(' ', $categoryNames) . ' ' . $typeId . ' ' . $displayCategory);

    $map = [
        'gpu' => ['gpu', 'graphics', 'graphics-card', 'geforce', 'rtx', 'radeon', 'vga'],
        'cpu' => ['cpu', 'processor', 'ryzen', 'threadripper', 'intel core', 'core i', 'xeon'],
        'laptop' => ['laptop', 'notebook', 'macbook', 'ultrabook'],
        'desktop' => ['desktop', 'pc', 'workstation', 'mac studio', 'mac mini', 'tower'],
    ];

    foreach ($map as $slug => $keywords) {
        foreach ($keywords as $keyword) {
            if (strpos($haystack, $keyword) !== false) {
                $slugs[] = $slug;
                break;
            }
        }
    }

    $displaySlug = $normalize($displayCategory);
    if ($displaySlug) {
        $slugs[] = $displaySlug;
    }

    foreach ($categoryNames as $categoryName) {
        $slug = $normalize($categoryName);
        if ($slug) {
            $slugs[] = $slug;
        }
    }

    return array_values(array_unique($slugs));
};

$getStockData = static function ($product) use ($stockRegistry, $getAttrText) {
    $preOrder = $getAttrText($product, 'pre_order') ?: $getAttrText($product, 'preorder');
    if ($preOrder && !in_array(strtolower($preOrder), ['0', 'no', 'false'], true)) {
        return ['code' => 'pre_order', 'label' => 'Pre-Order', 'class' => 'is-pre-order', 'order' => 2, 'qty' => null];
    }

    $qty = null;
    $isInStock = (bool) $product->isSaleable();

    try {
        $stockItem = $stockRegistry->getStockItem((int) $product->getId());
        if ($stockItem) {
            $qty = $stockItem->getQty() !== null ? (float) $stockItem->getQty() : null;
            $isInStock = (bool) $stockItem->getIsInStock() && (bool) $product->isSaleable();
        }
    } catch (\Throwable $e) {
    }

    if (!$isInStock) {
        return ['code' => 'out_of_stock', 'label' => 'Sold Out', 'class' => 'is-out-of-stock', 'order' => 3, 'qty' => 0];
    }

    if ($qty !== null && $qty > 0 && $qty <= 5) {
        return ['code' => 'low_stock', 'label' => 'Low Stock', 'class' => 'is-low-stock', 'order' => 1, 'qty' => $qty];
    }

    return ['code' => 'in_stock', 'label' => 'In Stock', 'class' => 'is-in-stock', 'order' => 0, 'qty' => $qty];
};

$getSpecs = static function ($product, $displayCategory, $brand) use ($getAttrText) {
    $specs = [];
    $specMap = [
        'graphics_card' => 'GPU',
        'gpu' => 'GPU',
        'processor' => 'CPU',
        'cpu' => 'CPU',
        'ram' => 'RAM',
        'memory' => 'Memory',
        'storage' => 'Storage',
        'screen_size' => 'Screen',
        'capacity' => 'Capacity',
        'color' => 'Color',
    ];

    foreach ($specMap as $code => $label) {
        $value = $getAttrText($product, $code);
        if ($value) {
            $specs[] = ['label' => $label, 'value' => $value];
        }
        if (count($specs) >= 3) {
            break;
        }
    }

    if (count($specs) < 3 && $brand) {
        $specs[] = ['label' => 'Brand', 'value' => $brand];
    }
    if (count($specs) < 3 && $displayCategory) {
        $specs[] = ['label' => 'Category', 'value' => $displayCategory];
    }
    if (count($specs) < 3) {
        $specs[] = ['label' => 'SKU', 'value' => (string) $product->getSku()];
    }

    return array_slice($specs, 0, 3);
};

