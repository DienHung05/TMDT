<?php
/** @var \Magento\Framework\View\Element\Template $block */

$om                       = \Magento\Framework\App\ObjectManager::getInstance();
$storeManager             = $om->get(\Magento\Store\Model\StoreManagerInterface::class);
$productCollectionFactory = $om->get(\Magento\Catalog\Model\ResourceModel\Product\CollectionFactory::class);
$visibility               = $om->get(\Magento\Catalog\Model\Product\Visibility::class);
$priceCurrency            = $om->get(\Magento\Framework\Pricing\PriceCurrencyInterface::class);
$imageHelper              = $om->get(\Magento\Catalog\Helper\Image::class);
$store                    = $storeManager->getStore();

$activeFilter = isset($_GET['filter']) ? htmlspecialchars((string) $_GET['filter'], ENT_QUOTES) : 'all';

/* ── Fetch products with special price ── */
$deals = [];
try {
    $collection = $productCollectionFactory->create();
    $collection->setStoreId((int) $store->getId())
        ->addStoreFilter($store)
        ->addAttributeToSelect(['name','small_image','image','price','special_price','special_from_date','special_to_date'])
        ->addFinalPrice()
        ->addUrlRewrite()
        ->addAttributeToFilter('status', 1)
        ->setVisibility($visibility->getVisibleInCatalogIds())
        ->addAttributeToFilter('special_price', ['notnull' => true])
        ->addAttributeToFilter('special_price', ['gt' => 0])
        ->setPageSize(60)
        ->setCurPage(1);
    $collection->getSelect()->order('e.entity_id DESC');
    $collection->load();

    $now = date('Y-m-d H:i:s');
    foreach ($collection as $product) {
        $regularPrice = (float) $product->getData('price');
        $specialPrice = (float) $product->getFinalPrice();
        if ($specialPrice <= 0 || $regularPrice <= 0 || $specialPrice >= $regularPrice) {
            continue;
        }
        $discountPct  = (int) round(100 * (1 - $specialPrice / $regularPrice));
        if ($discountPct < 1) { continue; }

        $imgUrl = (string) $imageHelper->init($product, 'category_page_grid')->getUrl();

        $deals[] = [
            'id'       => (int)    $product->getId(),
            'name'     => (string) $product->getName(),
            'url'      => (string) $product->getProductUrl(),
            'image'    => $imgUrl ?: '',
            'regular'  => $regularPrice,
            'special'  => $specialPrice,
            'discount' => $discountPct,
            'regular_html' => $priceCurrency->format($regularPrice, false),
            'special_html' => $priceCurrency->format($specialPrice, false),
        ];
    }
    /* Sort by biggest discount first */
    usort($deals, static function ($a, $b) { return $b['discount'] <=> $a['discount']; });
} catch (\Throwable $e) { /* silent */ }

/* ── Apply filter ── */
$filtered = $deals;
if ($activeFilter === 'under500') {
    $filtered = array_filter($deals, static fn($d) => $d['special'] < 500);
} elseif ($activeFilter === 'under1000') {
    $filtered = array_filter($deals, static fn($d) => $d['special'] >= 500 && $d['special'] < 1000);
} elseif ($activeFilter === 'under2000') {
    $filtered = array_filter($deals, static fn($d) => $d['special'] >= 1000 && $d['special'] < 2000);
} elseif ($activeFilter === 'under5pct') {
    $filtered = array_filter($deals, static fn($d) => $d['discount'] >= 5);
} elseif ($activeFilter === 'under10pct') {
    $filtered = array_filter($deals, static fn($d) => $d['discount'] >= 10);
}
$filtered  = array_values($filtered);
$totalDeals = count($deals);
$bestsellers = array_slice($deals, 0, 6); /* top 6 by discount = "best sellers" */
$bestseller_ids = array_column($bestsellers, 'id');

$filterTabs = [
    'all'       => ['label' => '🔥 All Deals',    'count' => count($deals)],
    'under500'  => ['label' => 'Under $500',       'count' => count(array_filter($deals, fn($d) => $d['special'] < 500))],
    'under1000' => ['label' => '$500 – $999',      'count' => count(array_filter($deals, fn($d) => $d['special'] >= 500 && $d['special'] < 1000))],
    'under2000' => ['label' => '$1,000 – $1,999',  'count' => count(array_filter($deals, fn($d) => $d['special'] >= 1000 && $d['special'] < 2000))],
    'under5pct' => ['label' => '5%+ Off',          'count' => count(array_filter($deals, fn($d) => $d['discount'] >= 5))],
    'under10pct'=> ['label' => '10%+ Off',         'count' => count(array_filter($deals, fn($d) => $d['discount'] >= 10))],
];
$dealsUrl = $block->getUrl('deals');
?>
<div class="pvd-page">

    <!-- ── Hero ── -->
    <div class="pvd-hero">
        <div class="pv3-container pvd-hero-inner">
            <div class="pvd-hero-kicker">⚡ Limited Time — While Stocks Last</div>
            <h1>Hot <span>Deals</span></h1>
            <p class="pvd-hero-sub">Biggest discounts on premium hardware — updated daily from our catalog.</p>
            <div class="pvd-hero-stats">
                <div class="pvd-stat">
                    <strong><?= $block->escapeHtml((string) $totalDeals) ?></strong>
                    <span>Active Deals</span>
                </div>
                <div class="pvd-stat">
                    <strong><?= $deals ? $block->escapeHtml((string) max(array_column($deals, 'discount'))) . '%' : '—' ?></strong>
                    <span>Max Savings</span>
                </div>
                <div class="pvd-stat">
                    <strong>Daily</strong>
                    <span>Updated</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Filter tabs ── -->
    <div class="pvd-filters">
        <div class="pv3-container">
            <div class="pvd-filter-tabs">
                <?php foreach ($filterTabs as $key => $tab): ?>
                <a href="<?= $block->escapeUrl($dealsUrl . '?filter=' . $key) ?>"
                   class="pvd-filter-tab<?= $activeFilter === $key ? ' is-active' : '' ?>">
                    <?= $block->escapeHtml($tab['label']) ?>
                    <?php if ($tab['count'] > 0): ?>
                    <span style="opacity:.7;font-size:11px;">(<?= $block->escapeHtml((string) $tab['count']) ?>)</span>
                    <?php endif; ?>
                </a>
                <?php endforeach; ?>
            </div>
        </div>
    </div>

    <div class="pv3-container">

        <?php if (!empty($filtered)): ?>

        <!-- ── Best Seller Banner ── -->
        <?php if ($activeFilter === 'all'): ?>
        <div class="pvd-banner">
            <div class="pvd-banner-inner">
                <span class="pvd-banner-bolt">🏆</span>
                <span class="pvd-banner-text">Best <span>Sellers</span></span>
                <span class="pvd-banner-bolt">🏆</span>
            </div>
        </div>
        <?php endif; ?>

        <!-- ── Product grid ── -->
        <div class="pvd-grid-section">
            <div class="pvd-products-grid">
                <?php foreach ($filtered as $i => $deal): ?>
                <?php $isBest = in_array($deal['id'], $bestseller_ids, true); ?>
                <article class="pvd-card<?= $isBest ? ' is-bestseller' : '' ?>">
                    <div class="pvd-card-badges">
                        <span class="pvd-badge pvd-badge--discount">-<?= $block->escapeHtml((string) $deal['discount']) ?>%</span>
                        <?php if ($isBest): ?>
                        <span class="pvd-badge pvd-badge--bestseller">⭐ Best Seller</span>
                        <?php endif; ?>
                        <?php if ($deal['discount'] >= 15): ?>
                        <span class="pvd-badge pvd-badge--hot">🔥 Hot Deal</span>
                        <?php endif; ?>
                    </div>
                    <a class="pvd-card-image" href="<?= $block->escapeUrl($deal['url']) ?>">
                        <?php if ($deal['image']): ?>
                        <img src="<?= $block->escapeUrl($deal['image']) ?>"
                             alt="<?= $block->escapeHtmlAttr($deal['name']) ?>" loading="lazy" />
                        <?php else: ?>
                        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="m9 9 6 6"/><path d="m15 9-6 6"/></svg>
                        <?php endif; ?>
                    </a>
                    <div class="pvd-card-body">
                        <p class="pvd-card-name">
                            <a href="<?= $block->escapeUrl($deal['url']) ?>"><?= $block->escapeHtml($deal['name']) ?></a>
                        </p>
                        <div class="pvd-prices">
                            <span class="pvd-price-special"><?= $block->escapeHtml($deal['special_html']) ?></span>
                            <span class="pvd-price-original"><?= $block->escapeHtml($deal['regular_html']) ?></span>
                        </div>
                        <a class="pvd-card-cta" href="<?= $block->escapeUrl($deal['url']) ?>">
                            <?= $block->escapeHtml(__('View Deal')) ?> →
                        </a>
                    </div>
                </article>
                <?php endforeach; ?>
            </div>
        </div>

        <?php else: ?>
        <div class="pvd-empty" style="padding-top:64px;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
                <line x1="7" y1="7" x2="7.01" y2="7"/>
            </svg>
            <p>No deals found for this filter.</p>
            <p style="font-size:13px;margin-top:8px;">
                To create deals: go to <a href="<?= $block->escapeUrl($block->getUrl('adminhtml')) ?>">Magento Admin</a>
                → Catalog → Products → set a <strong>Special Price</strong> on any product.
            </p>
            <a href="<?= $block->escapeUrl($dealsUrl) ?>" class="pvd-filter-tab is-active" style="margin-top:16px;display:inline-flex;">
                View All Deals
            </a>
        </div>
        <?php endif; ?>

    </div>
</div>
