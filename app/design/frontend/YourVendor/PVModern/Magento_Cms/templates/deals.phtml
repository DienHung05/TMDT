<?php
/** @var \Magento\Framework\View\Element\Template $block */
$om                       = \Magento\Framework\App\ObjectManager::getInstance();
$storeManager             = $om->get(\Magento\Store\Model\StoreManagerInterface::class);
$productCollectionFactory = $om->get(\Magento\Catalog\Model\ResourceModel\Product\CollectionFactory::class);
$visibility               = $om->get(\Magento\Catalog\Model\Product\Visibility::class);
$priceCurrency            = $om->get(\Magento\Framework\Pricing\PriceCurrencyInterface::class);
$imageHelper              = $om->get(\Magento\Catalog\Helper\Image::class);
$store                    = $storeManager->getStore();

$activeFilter = isset($_GET['filter']) ? htmlspecialchars((string)$_GET['filter'], ENT_QUOTES) : 'all';

/* ── Fetch sale products ─────────────────────────────────────────────────── */
$deals = [];
try {
    $collection = $productCollectionFactory->create();
    $collection->setStoreId((int)$store->getId())
        ->addStoreFilter($store)
        ->addAttributeToSelect(['name','small_image','price','special_price'])
        ->addFinalPrice()
        ->addUrlRewrite()
        ->addAttributeToFilter('status', 1)
        ->setVisibility($visibility->getVisibleInCatalogIds())
        ->addAttributeToFilter('special_price', ['notnull' => true])
        ->addAttributeToFilter('special_price', ['gt' => 0])
        ->setPageSize(60)
        ->setCurPage(1);
    $collection->getSelect()->order('e.entity_id DESC');
    $collection->load();

    foreach ($collection as $product) {
        $regular = (float)$product->getData('price');
        $special = (float)$product->getFinalPrice();
        if ($special <= 0 || $regular <= 0 || $special >= $regular) continue;
        $disc = (int)round(100 * (1 - $special / $regular));
        if ($disc < 1) continue;
        $deals[] = [
            'id'      => (int)$product->getId(),
            'name'    => (string)$product->getName(),
            'url'     => (string)$product->getProductUrl(),
            'image'   => (string)$imageHelper->init($product, 'category_page_grid')->getUrl(),
            'regular' => $regular,
            'special' => $special,
            'disc'    => $disc,
            'reg_fmt' => $priceCurrency->format($regular, false),
            'sp_fmt'  => $priceCurrency->format($special, false),
        ];
    }
    usort($deals, function ($a, $b) { return $b['disc'] - $a['disc']; });
} catch (\Throwable $e) { /* silent */ }

/* ── Filter helpers ──────────────────────────────────────────────────────── */
function _pvd_count($deals, $filter) {
    $c = 0;
    foreach ($deals as $d) {
        switch ($filter) {
            case 'hot':     if ($d['disc'] >= 20) $c++; break;
            case 'mid':     if ($d['disc'] >= 10 && $d['disc'] < 20) $c++; break;
            case 'budget':  if ($d['special'] < 500) $c++; break;
            default:        $c++; break;
        }
    }
    return $c;
}

$filtered = [];
foreach ($deals as $d) {
    switch ($activeFilter) {
        case 'hot':    if ($d['disc'] >= 20) $filtered[] = $d; break;
        case 'mid':    if ($d['disc'] >= 10 && $d['disc'] < 20) $filtered[] = $d; break;
        case 'budget': if ($d['special'] < 500) $filtered[] = $d; break;
        default:       $filtered[] = $d; break;
    }
}

$topIds   = array_column(array_slice($deals, 0, 8), 'id');
$dealsUrl = $escaper->escapeUrl($block->getUrl('deals'));
$maxDisc  = !empty($deals) ? max(array_column($deals, 'disc')) : 0;
$tabs = [
    'all'    => ['label' => 'All Deals',  'icon' => '&#x1F4E6;', 'count' => count($deals)],
    'hot'    => ['label' => '20%+ Off',   'icon' => '&#x26A1;',   'count' => _pvd_count($deals, 'hot')],
    'mid'    => ['label' => '10-19% Off', 'icon' => '&#x2714;',   'count' => _pvd_count($deals, 'mid')],
    'budget' => ['label' => 'Under $500', 'icon' => '&#x1F4B0;',  'count' => _pvd_count($deals, 'budget')],
];
?>

