<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="product.info.details">
            <block class="Magento\Framework\View\Element\Template"
                   name="pvmodern.product.specifications"
                   template="Magento_Catalog::product/view/specifications.phtml"
                   group="detailed_info">
                <arguments>
                    <argument name="title" xsi:type="string" translate="true">Specifications</argument>
                    <argument name="sort_order" xsi:type="string">15</argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
