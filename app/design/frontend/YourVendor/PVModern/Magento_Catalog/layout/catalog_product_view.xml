<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="product.info.review" remove="true" />

        <referenceContainer name="product.info.main">
            <block class="Magento\Framework\View\Element\Template"
                   name="pvmodern.product.specifications.summary"
                   template="Magento_Catalog::product/view/specifications.phtml"
                   after="product.info.review" />
        </referenceContainer>

        <!--
            Remove the "Specifications" tab from the product detail accordion.
            The specs now render as a right-column card and at the top of the
            Reviews tab, instead of as a separate tab button.
        -->
        <referenceBlock name="pvmodern.product.specifications" remove="true" />
    </body>
</page>
