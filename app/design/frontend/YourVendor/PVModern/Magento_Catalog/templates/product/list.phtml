/* MISSION 4: helper to safely fetch brand text from dropdown attribute */
function pvGetBrand($product)
{
    try {
        /* Try attribute text (label) — works for select/dropdown */
        $brand = $product->getAttributeText('brand');
        if ($brand && !is_array($brand)) return trim((string) $brand);
        if (is_array($brand) && !empty($brand)) return trim(implode(', ', $brand));

        /* Fall back to manufacturer attribute */
        $mfr = $product->getAttributeText('manufacturer');
        if ($mfr && !is_array($mfr)) return trim((string) $mfr);
        if (is_array($mfr) && !empty($mfr)) return trim(implode(', ', $mfr));

        /* Fall back to raw data value */
        $raw = $product->getData('brand') ?: $product->getData('manufacturer');
        if ($raw) return trim((string) $raw);
    } catch (\Throwable $e) {}
    return '';
}

