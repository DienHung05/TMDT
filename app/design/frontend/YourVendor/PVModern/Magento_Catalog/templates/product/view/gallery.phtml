<?php
/**
 * PVModern product gallery with resolver fallback for products that do not have stored Magento media yet.
 *
 * @var $block \Magento\Catalog\Block\Product\View\Gallery
 * @var $escaper \Magento\Framework\Escaper
 */
$imageWidth = $block->getImageAttribute('product_page_image_medium', 'width');
$imageHeight = $block->getImageAttribute('product_page_image_medium', 'height');
$mainImageData = (string) $block->getViewModel()->getMainProductImage();
$galleryJson = (string) $block->getGalleryImagesJson();
$product = $block->getProduct();

$om = \Magento\Framework\App\ObjectManager::getInstance();
$visualResolver = $om->get(\YourVendor\PVModern\Model\ProductVisualResolver::class);

$needsFallback = $mainImageData === ''
    || str_contains($mainImageData, 'placeholder')
    || str_contains($mainImageData, 'no_selection');

if ($needsFallback && $product) {
    $fallbackImage = $visualResolver->resolveProductImage($product, 'product_page_image_medium');
    $mainImageData = $fallbackImage;
    $galleryJson = json_encode([[
        'thumb' => $fallbackImage,
        'img' => $fallbackImage,
        'full' => $fallbackImage,
        'caption' => (string) $product->getName(),
        'position' => '1',
        'isMain' => true,
        'type' => 'image',
        'videoUrl' => null,
    ]], JSON_UNESCAPED_SLASHES) ?: '[]';
}
?>
<div class="gallery-placeholder _block-content-loading" data-gallery-role="gallery-placeholder">
    <img
        alt="main product photo"
        class="gallery-placeholder__image"
        src="<?= /* @noEscape */ $mainImageData ?>"
        <?= $imageWidth ? 'width="' . $escaper->escapeHtmlAttr($imageWidth) . '"' : '' ?>
        <?= $imageHeight ? 'height="' . $escaper->escapeHtmlAttr($imageHeight) . '"' : '' ?>
    />
    <link itemprop="image" href="<?= /* @noEscape */ $mainImageData ?>">
</div>
<?php // phpcs:ignore Magento2.Legacy.PhtmlTemplate ?>
<script type="text/x-magento-init">
    {
        "[data-gallery-role=gallery-placeholder]": {
            "mage/gallery/gallery": {
                "mixins":["magnifier/magnify"],
                "magnifierOpts": <?= /* @noEscape */ $block->getMagnifier() ?>,
                "data": <?= /* @noEscape */ $galleryJson ?>,
                "options": <?= /* @noEscape */ $block->getGalleryOptions()->getOptionsJson() ?>,
                "fullscreen": <?= /* @noEscape */ $block->getGalleryOptions()->getFSOptionsJson() ?>,
                "breakpoints": <?= /* @noEscape */ $block->getBreakpoints() ?>
            }
        }
    }
</script>
