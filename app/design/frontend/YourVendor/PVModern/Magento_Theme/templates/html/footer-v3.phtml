$_homeUrl = $block->getUrl('');
$_homeSearchUrl = static function (string $query = '') use ($_homeUrl): string {
    $query = trim($query);

    if ($query === '') {
        return $_homeUrl . '#pv3-products';
    }

    return $_homeUrl . '?q=' . rawurlencode($query) . '#pv3-products';
};
