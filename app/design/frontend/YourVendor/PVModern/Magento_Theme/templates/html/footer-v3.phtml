<?php
$_homeUrl = $block->getUrl('');
$_normalizeKey = static function (string $value): string {
    $value = strtolower(trim($value));
    $value = preg_replace('/[^a-z0-9]+/', '-', $value);
    return trim((string) $value, '-');
};
$_homeSearchUrl = static function (string $query = '') use ($_homeUrl): string {
    $query = trim($query);

    if ($query === '') {
        return $_homeUrl . '#pv3-products';
    }

    return $_homeUrl . '?q=' . rawurlencode($query) . '#pv3-products';
};
$_homeFilterUrl = static function (string $category = '') use ($_homeUrl, $_normalizeKey): string {
    $category = $_normalizeKey($category);

    if ($category === '') {
        return $_homeUrl . '#pv3-products';
    }

    return $_homeUrl . '?category=' . rawurlencode($category) . '#pv3-products';
};
