                <div class="pv3-nav-item" data-nav-key="<?= $_hKey ?>">

                    <!-- The <a> carries data-cat for JS targeting -->
                    <a href="<?= $block->escapeUrl($block->getUrl('')) ?>#pv3-products"
                       class="pv3-nav-link<?= ($_activeCat === $_key) ? ' is-active' : '' ?>"
                       data-cat="<?= $_hKey ?>"
                       aria-haspopup="true">
                        <?= $block->escapeHtml($_menu['label']) ?>
                        <span class="pv3-nav-caret" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <path d="m6 9 6 6 6-6"/>
                            </svg>
                        </span>
                    </a>

                    <!--
