<?php
/**
 * PVModern v4.1-fixed — Header
 * =============================
 * Navigation: pure CSS hover mega-menus, RequireJS sliding underline
 * Cart badge: Magento customerData (KO observable) real-time update
 * No Alpine.js dependency — works with stock Magento RequireJS stack.
 *
 * @var \Magento\Framework\View\Element\Template $block
 */

$_om = \Magento\Framework\App\ObjectManager::getInstance();
$_customerSession = $_om->get(\Magento\Customer\Model\Session::class);
$_isLoggedIn = false;
try {
    $_isLoggedIn = (bool) $_customerSession->isLoggedIn();
} catch (\Throwable $e) {}
$_logoutUrl = $block->escapeUrl($block->getUrl('customer/account/logout'));

/* ── Server-side cart count (initial render) ───────── */
$_cartQty = 0;
try {
    $_cartQty = (int) round(
        (float) $_om->get(\Magento\Checkout\Model\Session::class)
                    ->getQuote()->getItemsQty()
    );
} catch (\Throwable $e) {}

/* ── Page-context detection for nav underline ──────────────────────────────
 * PHP detects whether we are on a category page and which nav item is active.
 * Values are embedded as data-* attributes on the <nav> element.
 * The RequireJS widget (v3-header.js) reads these on DOMReady to set the
 * initial underline position and text color — no page-load flash.
 * ─────────────────────────────────────────────────────────────────────────── */
$_req       = $_om->get(\Magento\Framework\App\RequestInterface::class);
$_action    = $_req->getFullActionName();
$_isCatPage = ($_action === 'catalog_category_view');
$_searchUrl = $block->getUrl('');
$_menus = $_om->get(\YourVendor\PVModern\Model\CategoryNavigation::class)->getMenuConfig();

$_activeCat = '';
$_normalizeKey = static function (string $value): string {
    $value = strtolower(trim($value));
    $value = preg_replace('/[^a-z0-9]+/', '-', $value);
    return trim((string) $value, '-');
};

$_categoryParam = $_normalizeKey((string) $_req->getParam('category', ''));
$_isFilterPage = ($_action === 'cms_index_index' && $_categoryParam !== '');

if ($_categoryParam !== '') {
    foreach ($_menus as $_menuKey => $_menu) {
        $_topSlug = $_normalizeKey((string) ($_menu['category'] ?? $_menu['label'] ?? $_menuKey));
        if ($_categoryParam === $_topSlug || $_categoryParam === $_menuKey) {
            $_activeCat = (string) $_menuKey;
            break;
        }

        foreach ((array) ($_menu['cols'] ?? []) as $_col) {
            foreach ((array) ($_col['links'] ?? []) as $_link) {
                if (!empty($_link['category']) && $_normalizeKey((string) $_link['category']) === $_categoryParam) {
                    $_activeCat = (string) $_menuKey;
                    break 3;
                }
            }
        }
    }
}

if ($_isCatPage) {
    try {
        $_cat = $_om->get(\Magento\Framework\Registry::class)->registry('current_category');
        if ($_cat) {
            $_nm  = strtolower((string) $_cat->getName());
            $_map = [
                'desktop' => ['desktop', 'pc', 'workstation', 'tower'],
                'laptop'  => ['laptop',  'notebook', 'macbook', 'ultrabook'],
                'monitor' => ['monitor', 'display',  'lcd',     'oled', 'screen'],
                'apple'   => ['apple',   'iphone',   'ipad',    'airpod', 'mac'],
            ];
            foreach ($_map as $_k => $_kws) {
                foreach ($_kws as $_kw) {
                    if (strpos($_nm, $_kw) !== false) {
                        $_activeCat = $_k;
                        break 2;
                    }
                }
            }
        }
    } catch (\Throwable $e) {}
}

$_buildSearchUrl = static function (string $query) use ($_searchUrl): string {
    return trim($query) === ''
        ? $_searchUrl . '#pv3-products'
        : $_searchUrl . '?q=' . rawurlencode($query) . '#pv3-products';
};

$_buildCategoryFilterUrl = static function (string $category) use ($_searchUrl, $_normalizeKey): string {
    $_slug = $_normalizeKey($category);
    return $_slug === ''
        ? $_searchUrl . '#pv3-products'
        : $_searchUrl . '?category=' . rawurlencode($_slug) . '#pv3-products';
};

$_resolveMenuLink = static function (array $_link) use ($_buildCategoryFilterUrl, $block, $_buildSearchUrl): string {
    // Explicit full URL
    if (!empty($_link['url'])) {
        return $block->getUrl($_link['url']);
    }
    // Route category links to the storefront filter state so the customer
    // lands on a visibly filtered product grid instead of an unrelated page.
    if (!empty($_link['category'])) {
        return $_buildCategoryFilterUrl((string) $_link['category']);
    }
    return $_buildSearchUrl((string) ($_link['q'] ?? ''));
};

$_searchUrl        = $block->escapeUrl($_searchUrl);

$_searchSuggestUrl = $block->escapeUrl($block->getUrl('pvmodern/search/suggest'));
$_trackingUrl      = $block->escapeUrl($block->getUrl('pvmodern/orders/tracking'));
$_trackingPageUrl  = $block->escapeUrl($block->getUrl('order-tracking'));

$_searchQuery      = trim((string) $_req->getParam('q', ''));
$_isCatStr         = ($_isCatPage || $_isFilterPage) ? 'true' : 'false';
$_activeStr        = $block->escapeHtmlAttr($_activeCat);
?>
<?php /* ── Google Fonts: Inter ── */ ?>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

