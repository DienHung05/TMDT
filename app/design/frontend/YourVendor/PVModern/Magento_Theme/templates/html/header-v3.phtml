            <!-- NAV ────────────────────────────────────────────────────────────
                 data-cat-page  → 'true'|'false'  — PHP page-type detection
                 data-active    → nav key          — PHP category name mapping
                 RequireJS widget reads these two attributes to:
                   1. Set initial underline position (category pages only)
                   2. Animate underline on hover (all pages)
                   3. Color the active link blue (category pages)
            ──────────────────────────────────────────────────────────────────── -->
            <nav class="pv3-nav"
                 id="pv3-nav"
                 aria-label="Primary navigation"
                 data-cat-page="<?= $_isCatStr ?>"
                 data-active="<?= $_activeStr ?>">

                <?php foreach ($_menus as $_key => $_menu): ?>
                <?php $_hKey = $block->escapeHtmlAttr($_key); ?>

                <div class="pv3-nav-item" data-nav-key="<?= $_hKey ?>">

                    <?php
                    /* Resolve top-level link: supports 'category', 'url', and 'q' keys */
                    $_topLink = $_resolveMenuLink($_menu);
                    ?>
                    <a href="<?= $block->escapeUrl($_topLink) ?>"
                       class="pv3-nav-link<?= ($_activeCat === $_key) ? ' is-active' : '' ?>"
                       data-cat="<?= $_hKey ?>"
                       aria-haspopup="true">
                        <?= $block->escapeHtml($_menu['label']) ?>
                        <span class="pv3-nav-caret" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <path d="m6 9 6 6 6-6"/>
                            </svg>
                        </span>
                    </a>

                    <!--
                        Mega-menu — shown/hidden by CSS :hover on .pv3-nav-item.
                        padding-top:20px on .pv3-mega-menu creates a transparent
                        hover bridge so the cursor can travel from link to panel.
                    -->
                    <div class="pv3-mega-menu" role="region"
                         aria-label="<?= $block->escapeHtmlAttr($_menu['label']) ?> submenu">
                        <div class="pv3-mega-inner">
                            <?php foreach ($_menu['cols'] as $_col): ?>
                            <div class="pv3-mega-col">
                                <strong class="pv3-mega-col-title">
                                    <?= $block->escapeHtml($_col['title']) ?>
                                </strong>
                                <ul>
                                    <?php foreach ($_col['links'] as $_link): ?>
                                    <li>
                                        <a href="<?= $block->escapeUrl($_resolveMenuLink($_link)) ?>">
                                            <?= $block->escapeHtml($_link['label']) ?>
                                        </a>
                                    </li>
                                    <?php endforeach; ?>
                                </ul>
                            </div>
                            <?php endforeach; ?>
                        </div>
                    </div>

                </div>
                <?php endforeach; ?>

                <!-- Deals — no dropdown -->
                <a class="pv3-nav-link is-deals"
                   data-cat="deals"
                   href="<?= $block->escapeUrl($block->getUrl('deals')) ?>">Deals</a>

                <!--
                    UNDERLINE INDICATOR
                    Positioned & animated by v3-header.js.
                    CSS: position:absolute; bottom:0; transition: left .28s, width .28s
                    JS sets: indicator.style.left, indicator.style.width, indicator.style.opacity
                    Hidden by default (opacity:0 in CSS). JS reveals it only when appropriate.
                -->
                <span class="pv3-nav-indicator" id="pv3-nav-indicator" aria-hidden="true"></span>

            </nav>

            <a class="pv3-tracking-button"
