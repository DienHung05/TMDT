/**
 * PVModern v4.1-fixed — Header
 * =============================
 * Navigation: pure CSS hover mega-menus, RequireJS sliding underline
 * Cart badge: Magento customerData (KO observable) real-time update
 * No Alpine.js dependency — works with stock Magento RequireJS stack.
 *
 * @var \Magento\Framework\View\Element\Template $block
 */

$_om = \Magento\Framework\App\ObjectManager::getInstance();

/* ── Server-side cart count (initial render) ───────── */
$_cartQty = 0;
try {
    $_cartQty = (int) round(
        (float) $_om->get(\Magento\Checkout\Model\Session::class)
                    ->getQuote()->getItemsQty()
    );
} catch (\Throwable $e) {}

/* ── Page-context detection for nav underline ──────────────────────────────
 * PHP detects whether we are on a category page and which nav item is active.
 * Values are embedded as data-* attributes on the <nav> element.
 * The RequireJS widget (v3-header.js) reads these on DOMReady to set the
 * initial underline position and text color — no page-load flash.
 * ─────────────────────────────────────────────────────────────────────────── */
$_req       = $_om->get(\Magento\Framework\App\RequestInterface::class);
$_action    = $_req->getFullActionName();
$_isCatPage = ($_action === 'catalog_category_view');
$_searchUrl = $block->getUrl('');

$_activeCat = '';
if ($_isCatPage) {
    try {
        $_cat = $_om->get(\Magento\Framework\Registry::class)->registry('current_category');
        if ($_cat) {
            $_nm  = strtolower((string) $_cat->getName());
            $_map = [
                'desktop' => ['desktop', 'pc', 'workstation', 'tower'],
                'laptop'  => ['laptop',  'notebook', 'macbook', 'ultrabook'],
                'monitor' => ['monitor', 'display',  'lcd',     'oled', 'screen'],
                'apple'   => ['apple',   'iphone',   'ipad',    'airpod', 'mac'],
            ];
            foreach ($_map as $_k => $_kws) {
                foreach ($_kws as $_kw) {
                    if (strpos($_nm, $_kw) !== false) {
                        $_activeCat = $_k;
                        break 2;
                    }
                }
            }
        }
    } catch (\Throwable $e) {}
}

$_normalizeKey = static function (string $value): string {
    $value = strtolower(trim($value));
    $value = preg_replace('/[^a-z0-9]+/', '-', $value);
    return trim((string) $value, '-');
};

/* ── Build category map: ALL active categories keyed by normalised name ──────
 * Load every active category store-wide (not just root children) so every
 * nav link — top-level AND subcategory — resolves to its own category page.
 * ─────────────────────────────────────────────────────────────────────────── */
$_categoryCollectionFactory = $_om->get(\Magento\Catalog\Model\ResourceModel\Category\CollectionFactory::class);
$_categoryMap = [];

try {
    $_allCats = $_categoryCollectionFactory->create();
    $_allCats->addAttributeToSelect(['name', 'url_key', 'url_path', 'is_active', 'level'])
             ->addAttributeToFilter('is_active', 1)
             ->addAttributeToFilter('entity_id', ['nin' => [1, 2]]);

    foreach ($_allCats as $_cat) {
        $_key = $_normalizeKey((string) $_cat->getName());
        if (!isset($_categoryMap[$_key])) {
            $_categoryMap[$_key] = $_cat;
        }
    }
} catch (\Throwable $e) {}

$_buildSearchUrl = static function (string $query) use ($_searchUrl): string {
    return trim($query) === ''
        ? $_searchUrl . '#pv3-products'
        : $_searchUrl . '?q=' . rawurlencode($query) . '#pv3-products';
};

$_resolveMenuLink = static function (array $_link) use ($_categoryMap, $_normalizeKey, $block, $_buildSearchUrl): string {
    // Explicit full URL
    if (!empty($_link['url'])) {
        return $block->getUrl($_link['url']);
    }
    // Resolve by category name → real Magento category URL
    if (!empty($_link['category'])) {
        $_key = $_normalizeKey((string) $_link['category']);
        if (!empty($_categoryMap[$_key])) {
            try { return (string) $_categoryMap[$_key]->getUrl(); } catch (\Throwable $e) {}
        }
        // Fallback: search on home page
        return $_buildSearchUrl((string) $_link['category']);
    }
    return $_buildSearchUrl((string) ($_link['q'] ?? ''));
};

