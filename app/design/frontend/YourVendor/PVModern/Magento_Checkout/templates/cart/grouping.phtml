<?php /** @var \Magento\Framework\View\Element\Template $block */ ?>
<script>
    require(['jquery'], function($) {
        $(document).ready(function() {
            var rawSessionVal = window.sessionStorage.getItem('pv_custom_pc_cart');
            if (rawSessionVal) {
                try {
                    var pcParts = JSON.parse(rawSessionVal);
                    if (pcParts && pcParts.length > 0) {
                        var skuList = pcParts.map(function(p) { return p.sku; });
                        var matchedRows = [];
                        
                        $('#shopping-cart-table tbody.cart.item').each(function() {
                            var $row = $(this);
                            var $input = $row.find('input[data-cart-item-id]');
                            if ($input.length) {
                                var rowSku = $input.attr('data-cart-item-id');
                                if (skuList.indexOf(rowSku) !== -1) {
                                    matchedRows.push($row);
                                }
                            }
                        });
                        
                        if (matchedRows.length > 0) {
                            var svgIcon = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 8px; margin-top:-2px;"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>';
                            var $groupHeader = $('<tbody class="pv3-pc-build-group"><tr><td colspan="10" style="background: linear-gradient(135deg, #2563eb, #3b82f6); color: white; padding: 12px 20px; font-weight: bold; border-radius: 8px 8px 0 0;">' + svgIcon + ' Khách Build PC Custom</td></tr></tbody>');
                            
                            matchedRows[0].before($groupHeader);
                            matchedRows.forEach(function($row) {
                                $row.css({
                                    'background-color': '#f8fafc',
                                    'box-shadow': 'inset 4px 0 0 #3b82f6'
                                });
                            });
                        }
                    }
                } catch(e) {}
            }
        });
    });
</script>
