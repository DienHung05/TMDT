<?php
/**
 * PVModern Cart Item – reference-faithful layout.
 * Matches: CartItemComponent.tsx from /reference/tmp
 */

// phpcs:disable Magento2.Templates.ThisInTemplate
// phpcs:disable Generic.Files.LineLength

/** @var $block \Magento\Checkout\Block\Cart\Item\Renderer */
/** @var \Magento\Framework\Escaper $escaper */

$_item   = $block->getItem();
$product = $_item->getProduct();
$helper  = $this->helper(Magento\Msrp\Helper\Data::class);
$priceHelper = $this->helper(Magento\Framework\Pricing\Helper\Data::class);
$cartHelper = $this->helper(Magento\Checkout\Helper\Cart::class);
$canApplyMsrp = $helper->isShowBeforeOrderConfirm($product) && $helper->isMinimalPriceLessMsrp($product);
$brand = $product->getAttributeText('manufacturer');
$brand = is_array($brand) ? implode(', ', $brand) : (string) $brand;
$brand = trim($brand) ?: (string) __('Techieworld');
$removePostJson = (string) $cartHelper->getDeletePostJson($_item);

$regularPrice = (float) $product->getPrice();
$finalPrice   = (float) $_item->getCalculationPrice();
$rowTotal     = (float) $_item->getRowTotal();
$discountPct  = ($regularPrice > 0 && $regularPrice > $finalPrice)
    ? (int) round((1 - $finalPrice / $regularPrice) * 100) : 0;
?>
<tbody class="cart item">
    <tr class="item-info">
        <td data-th="<?= $escaper->escapeHtml(__('Sản phẩm')) ?>" class="col item">
            <div class="pvcart-item-wrap">

                <!-- Thumbnail -->
                <div class="pvcart-item-thumb">
                    <?php if ($block->hasProductUrl()): ?>
                        <a href="<?= $escaper->escapeUrl($block->getProductUrl()) ?>"
                           title="<?= $escaper->escapeHtmlAttr($block->getProductName()) ?>"
                           class="pvcart-thumb-link">
                    <?php else: ?>
                        <span class="pvcart-thumb-link">
                    <?php endif ?>
                        <?= $block->getImage($block->getProductForThumbnail(), 'cart_page_product_thumbnail')->toHtml() ?>
                    <?php if ($block->hasProductUrl()): ?>
                        </a>
                    <?php else: ?>
                        </span>
                    <?php endif ?>
                </div>

                <!-- Details -->
                <div class="pvcart-item-details">
                    <div class="pvcart-item-badge-row">
                        <?php if ($discountPct > 0): ?>
                            <span class="pvcart-badge pvcart-badge--sale">Sale</span>
                        <?php endif ?>
                    </div>

                    <strong class="pvcart-item-name">
                        <?php if ($block->hasProductUrl()): ?>
                            <a href="<?= $escaper->escapeUrl($block->getProductUrl()) ?>">
                                <?= $escaper->escapeHtml($block->getProductName()) ?>
                            </a>
                        <?php else: ?>
                            <?= $escaper->escapeHtml($block->getProductName()) ?>
                        <?php endif ?>
                    </strong>

                    <p class="pvcart-item-seller"><?= $escaper->escapeHtml($brand) ?></p>

                    <!-- Price row -->
                    <div class="pvcart-item-price-row">
                        <?php if ($canApplyMsrp): ?>
                            <span class="pricing msrp">
                                <span class="msrp notice"><?= $escaper->escapeHtml(__('See price before order confirmation.')) ?></span>
                            </span>
                        <?php else: ?>
                            <span class="pvcart-current-price"><?= /* @noEscape */ $priceHelper->currency($finalPrice, true, false) ?></span>
                            <?php if ($discountPct > 0): ?>
                                <span class="pvcart-original-price"><?= /* @noEscape */ $priceHelper->currency($regularPrice, true, false) ?></span>
                            <?php endif ?>
                        <?php endif ?>
                        <?php if ($discountPct > 0): ?>
                            <span class="pvcart-discount-badge">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="11" height="11" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                                -<?= $discountPct ?>%
                            </span>
                        <?php endif ?>
                    </div>

                    <?php if ($_options = $block->getOptionList()): ?>
                        <dl class="item-options pvcart-options">
                            <?php foreach ($_options as $_option): ?>
                                <?php $_formattedOptionValue = $block->getFormatedOptionValue($_option) ?>
                                <dt><?= $escaper->escapeHtml($_option['label']) ?></dt>
                                <dd>
                                    <?php if (isset($_formattedOptionValue['full_view'])): ?>
                                        <?= $escaper->escapeHtml($_formattedOptionValue['full_view'], ['span','a']) ?>
                                    <?php else: ?>
                                        <?= $escaper->escapeHtml($_formattedOptionValue['value'], ['span','a']) ?>
                                    <?php endif ?>
                                </dd>
                            <?php endforeach ?>
                        </dl>
                    <?php endif ?>

                    <?php if ($messages = $block->getMessages()): ?>
                        <?php foreach ($messages as $message): ?>
                            <div class="cart item message <?= $escaper->escapeHtmlAttr($message['type']) ?>">
                                <div><?= $escaper->escapeHtml($message['text']) ?></div>
                            </div>
                        <?php endforeach ?>
                    <?php endif ?>

                    <?php $addInfoBlock = $block->getProductAdditionalInformationBlock(); ?>
                    <?php if ($addInfoBlock): ?>
                        <?= $addInfoBlock->setItem($_item)->toHtml() ?>
                    <?php endif ?>

                    <!-- Qty stepper -->
                    <div class="pvcart-item-controls">
                        <div class="pvcart-stepper">
                            <button type="button"
                                    class="pvcart-stepper-btn"
                                    data-qty-step="-1"
                                    aria-label="<?= $escaper->escapeHtmlAttr(__('Giảm số lượng')) ?>">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14"/></svg>
                            </button>
                            <label for="cart-<?= $escaper->escapeHtmlAttr($_item->getId()) ?>-qty">
                                <span class="sr-only"><?= $escaper->escapeHtml(__('Qty')) ?></span>
                                <input id="cart-<?= $escaper->escapeHtmlAttr($_item->getId()) ?>-qty"
                                       name="cart[<?= $escaper->escapeHtmlAttr($_item->getId()) ?>][qty]"
                                       data-cart-item-id="<?= $escaper->escapeHtmlAttr($_item->getSku()) ?>"
                                       value="<?= $escaper->escapeHtmlAttr($block->getQty()) ?>"
                                       type="number"
                                       min="0"
                                       size="4"
                                       step="any"
                                       title="<?= $escaper->escapeHtmlAttr(__('Qty')) ?>"
                                       class="pvcart-qty-input"
                                       data-validate="{required:true,'validate-greater-than-zero':true}"
                                       data-item-qty="<?= $escaper->escapeHtmlAttr($block->getQty()) ?>"
                                       data-role="cart-item-qty"/>
                            </label>
                            <button type="button"
                                    class="pvcart-stepper-btn"
                                    data-qty-step="1"
                                    aria-label="<?= $escaper->escapeHtmlAttr(__('Tăng số lượng')) ?>">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Right: item total -->
                <div class="pvcart-item-side">
                    <p class="pvcart-total-label"><?= $escaper->escapeHtml(__('Tổng')) ?></p>
                    <strong class="pvcart-total-value">
                        <?php if ($canApplyMsrp): ?>
                            --
                        <?php else: ?>
                            <?= /* @noEscape */ $priceHelper->currency($rowTotal, true, false) ?>
                        <?php endif ?>
                    </strong>

                    <?php if ($removePostJson): ?>
                        <a href="#"
                           class="pvcart-remove-btn"
                           title="<?= $escaper->escapeHtmlAttr(__('Xóa')) ?>"
                           data-post='<?= /* @noEscape */ $removePostJson ?>'>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="17" height="17" aria-hidden="true">
                                <path d="M3 6h18"/><path d="M8 6V4h8v2"/><path d="M19 6l-1 14H6L5 6"/>
                                <path d="M10 11v6"/><path d="M14 11v6"/>
                            </svg>
                            <span class="sr-only"><?= $escaper->escapeHtml(__('Xóa')) ?></span>
                        </a>
                    <?php endif ?>
                </div>

            </div><!-- /.pvcart-item-wrap -->
        </td>
    </tr>
</tbody>
