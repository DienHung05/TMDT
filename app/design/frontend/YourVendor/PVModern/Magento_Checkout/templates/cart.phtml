<?php
/**
 * PVModern cart page wrapper.
 *
 * Keeps Magento's with-items / no-items branching intact while ensuring both
 * states share the same outer cart shell.
 *
 * @var $block \Magento\Checkout\Block\Cart
 * @var \Magento\Framework\Escaper $escaper
 */
?>
<div class="pvcart-page cart-flow-page<?= $block->getItemsCount() ? '' : ' pvcart-page--empty' ?>">
    <div class="cart-page-top">
        <nav class="pvcart-breadcrumb cart-breadcrumb" aria-label="<?= $escaper->escapeHtmlAttr(__('Breadcrumb')) ?>">
            <a href="<?= $escaper->escapeUrl($block->getUrl('')) ?>"><?= $escaper->escapeHtml(__('Trang chủ')) ?></a>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="m9 18 6-6-6-6"/>
            </svg>
            <span><?= $escaper->escapeHtml(__('Giỏ hàng')) ?></span>
        </nav>
        <div class="cart-label"><?= $escaper->escapeHtml(__('Giỏ hàng')) ?></div>
        <h1 class="pvcart-title cart-title"><?= $escaper->escapeHtml(__('Giỏ hàng của bạn')) ?></h1>
    </div>

    <?php if ($block->getItemsCount()): ?>
        <?= $block->getChildHtml('with-items') ?>
    <?php else: ?>
        <?= $block->getChildHtml('no-items') ?>
    <?php endif; ?>
</div>
