<?php
/**
 * @var $block \Vendor\News\Block\News
 */
$news = $block->getNews();
?>

<div class="vnexpress-news">
    <h1 class="page-title">Tin tức mới nhất từ VnExpress</h1>

    <?php if (empty($news)): ?>
        <div class="message info">
            <span>Không thể tải tin tức. Vui lòng thử lại sau.</span>
        </div>
    <?php else: ?>
        <ul class="news-list">
            <?php foreach ($news as $item): ?>
                <li class="news-item">
                    <h2 class="news-title">
                        <a href="<?= $block->escapeUrl($item['link']) ?>" target="_blank" rel="nofollow">
                            <?= $block->escapeHtml($item['title']) ?>
                        </a>
                    </h2>
                    <div class="news-date">
                        <?= $block->escapeHtml($block->formatDate($item['pubDate'])) ?>
                    </div>
                    <div class="news-description">
                        <?= $block->escapeHtml(substr(strip_tags($item['description']), 0, 200)) ?>...
                    </div>
                    <a href="<?= $block->escapeUrl($item['link']) ?>" class="read-more" target="_blank">
                        Đọc tiếp →
                    </a>
                </li>
            <?php endforeach; ?>
        </ul>
    <?php endif; ?>
</div>

