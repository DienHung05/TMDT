<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:App/etc/routes.xsd">
    <router id="standard">
        <!-- /deals -->
        <route id="deals" frontName="deals">
            <module name="YourVendor_PVModern"/>
        </route>
        <!-- /terms -->
        <route id="terms" frontName="terms">
            <module name="YourVendor_PVModern"/>
        </route>
        <!-- /privacy -->
        <route id="privacy" frontName="privacy">
            <module name="YourVendor_PVModern"/>
        </route>
        <!-- /cookies -->
        <route id="cookies" frontName="cookies">
            <module name="YourVendor_PVModern"/>
        </route>
        <!-- /pcbuilder -->
        <route id="pcbuilder" frontName="pcbuilder">
            <module name="YourVendor_PVModern"/>
        </route>
        <!-- /pc-builder -->
        <route id="pc_builder" frontName="pc-builder">
            <module name="YourVendor_PVModern"/>
        </route>
        <!-- /warranty -->
        <route id="warranty" frontName="warranty">
            <module name="YourVendor_PVModern"/>
        </route>
        <!-- /news -->
        <route id="news" frontName="news">
            <module name="YourVendor_PVModern"/>
        </route>
        <!-- /weather -->
        <route id="weather" frontName="weather">
            <module name="YourVendor_PVModern"/>
        </route>
        <!-- /currency-rate -->
        <route id="currency_rate" frontName="currency-rate">
            <module name="YourVendor_PVModern"/>
        </route>
        <!-- /order-tracking -->
        <route id="order_tracking" frontName="order-tracking">
            <module name="YourVendor_PVModern"/>
        </route>
        <!-- /pvmodern — generic API-style routes (e.g. search/suggest) -->
        <route id="pvmodern" frontName="pvmodern">
            <module name="YourVendor_PVModern"/>
        </route>
        <!-- /api aliases for frontend dashboards; Magento Webapi remains fallback. -->
        <route id="api" frontName="api">
            <module name="YourVendor_PVModern" before="Magento_Webapi"/>
        </route>
    </router>
</config>
