<?xml version="1.0"?>
<page layout="1column"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <attribute name="class" value="pvmodern-warranty-page"/>
        <referenceBlock name="breadcrumbs" remove="true"/>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceBlock name="sidebar.main" remove="true"/>
        <referenceBlock name="sidebar.additional" remove="true"/>
        <referenceContainer name="sidebar.main" remove="true"/>
        <referenceContainer name="sidebar.additional" remove="true"/>
        <referenceContainer name="content">
            <block class="YourVendor\PVModern\Block\Warranty\Lookup"
                   name="pvmodern.warranty.lookup"
                   template="YourVendor_PVModern::warranty/lookup.phtml"
                   cacheable="false"/>
        </referenceContainer>
    </body>
</page>
